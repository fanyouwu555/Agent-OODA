{
  "name": "ooda-agent",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "OODA-based AI Agent with ReAct and PEV architecture",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node --import tsx scripts/start.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:app\"",
    "dev:server": "npm run dev --workspace @ooda-agent/server",
    "dev:app": "npm run dev --workspace @ooda-agent/app",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:memory": "tsx tests/memory-test.ts",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "djwt": "^2.0.0"
  }
}
