{
  "$schema": "https://ooda-agent.ai/config.v2.json",
  "version": "2.0",
  
  "provider": {
    "local-ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "token-unused"
      },
      "models": {
        "qwen3:8b": {
          "name": "qwen3",
          "temperature": 0.7,
          "maxTokens": 2000
        }
      }
    },
    "openai": {
      "name": "openai",
      "options": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "models": {
        "gpt-4": {
          "name": "gpt-4",
          "temperature": 0.7,
          "maxTokens": 2000
        }
      }
    }
  },

  "permission": {
    "global": {
      "defaultMode": "ask",
      "tools": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "write": "ask",
        "edit": "ask",
        "bash": "ask",
        "webfetch": "ask"
      },
      "skills": {
        "data_analysis": "ask",
        "image_processing": "ask",
        "pdf_processing": "ask",
        "code_analysis": "allow"
      }
    },
    "groups": {
      "readonly": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow"
      },
      "dangerous": {
        "bash": "deny",
        "write": "ask"
      }
    }
  },

  "tools": {
    "groups": {
      "filesystem": {
        "name": "filesystem",
        "displayName": "文件系统",
        "tools": ["read", "write", "edit", "list", "glob"]
      },
      "search": {
        "name": "search",
        "displayName": "搜索工具",
        "tools": ["grep", "glob"]
      },
      "network": {
        "name": "network",
        "displayName": "网络工具",
        "tools": ["webfetch"]
      }
    }
  },

  "skills": {
    "groups": {
      "data": {
        "name": "data",
        "displayName": "数据处理",
        "skills": ["data_analysis", "database_query"]
      },
      "media": {
        "name": "media",
        "displayName": "媒体处理",
        "skills": ["image_processing", "pdf_processing"]
      }
    }
  },

  "agents": {
    "default": "build",
    
    "templates": {
      "base": {
        "name": "base",
        "description": "基础Agent模板",
        "config": {
          "systemPrompt": "你是一个AI助手。",
          "model": {
            "name": "qwen3",
            "temperature": 0.7,
            "maxTokens": 2000
          },
          "runtime": {
            "maxSteps": 50,
            "timeout": 300000
          }
        }
      }
    },
    
    "definitions": {
      "build": {
        "name": "build",
        "displayName": "代码构建",
        "description": "专业的代码编写助手，擅长编写高质量、可维护的代码",
        "extends": "base",
        "metadata": {
          "icon": "🔨",
          "tags": ["code", "development", "programming"],
          "author": "OODA Team",
          "version": "1.0.0",
          "examples": [
            "帮我实现一个用户登录功能",
            "写一个API接口处理用户注册"
          ]
        },
        "triggers": {
          "keywords": ["写代码", "实现", "构建", "开发", "编写", "编程"],
          "patterns": ["^(创建|编写|实现|开发).*$"],
          "fileTypes": [".ts", ".js", ".py", ".java", ".go"]
        },
        "systemPrompt": "你是一个专业的代码编写助手，擅长编写高质量、可维护的代码。你应该遵循最佳实践，编写清晰、简洁的代码。",
        "tools": {
          "allowed": ["read", "write", "edit", "bash", "grep", "glob", "list"],
          "groups": ["filesystem", "search"]
        },
        "skills": {
          "allowed": ["code_analysis"],
          "autoInitialize": ["code_analysis"]
        },
        "permissions": {
          "inherit": true,
          "tools": {
            "bash": "ask",
            "write": "ask"
          },
          "patterns": [
            {
              "pattern": "bash:rm*",
              "mode": "deny"
            }
          ]
        },
        "model": {
          "temperature": 0.7,
          "maxTokens": 4000
        },
        "runtime": {
          "maxSteps": 100,
          "timeout": 600000
        }
      },
      
      "plan": {
        "name": "plan",
        "displayName": "任务规划",
        "description": "任务规划专家，擅长分析需求并制定详细的执行计划",
        "extends": "base",
        "metadata": {
          "icon": "📋",
          "tags": ["planning", "analysis", "strategy"],
          "examples": [
            "帮我规划这个项目的开发流程",
            "分析一下这个需求的实现步骤"
          ]
        },
        "triggers": {
          "keywords": ["规划", "计划", "分析", "设计", "方案"],
          "patterns": ["^(规划|计划|分析|设计).*$"]
        },
        "systemPrompt": "你是一个任务规划专家，擅长分析需求并制定详细的执行计划。你应该考虑各种可能的情况，制定周全的计划。",
        "tools": {
          "allowed": ["read", "grep", "glob", "list"],
          "groups": ["readonly"]
        },
        "permissions": {
          "inherit": false,
          "tools": {
            "read": "allow",
            "grep": "allow",
            "glob": "allow",
            "list": "allow"
          }
        },
        "model": {
          "temperature": 0.5,
          "maxTokens": 1500
        }
      },
      
      "general": {
        "name": "general",
        "displayName": "通用助手",
        "description": "通用AI助手，可以处理各种任务",
        "extends": "base",
        "metadata": {
          "icon": "🤖",
          "tags": ["general", "assistant", "chat"]
        },
        "systemPrompt": "你是一个通用的AI助手，可以处理各种任务。你应该根据用户的需求，提供准确、有用的回答。",
        "tools": {
          "allowed": ["read", "write", "edit", "bash", "grep", "glob", "list", "webfetch"],
          "groups": ["filesystem", "search", "network"]
        },
        "permissions": {
          "inherit": true
        }
      },
      
      "explore": {
        "name": "explore",
        "displayName": "代码探索",
        "description": "代码探索专家，擅长分析代码结构和理解项目",
        "extends": "base",
        "metadata": {
          "icon": "🔍",
          "tags": ["explore", "codebase", "analysis"]
        },
        "triggers": {
          "keywords": ["探索", "查找", "搜索", "分析代码"],
          "fileTypes": [".ts", ".js", ".py", ".java", ".go", ".rs"]
        },
        "systemPrompt": "你是一个代码探索专家，擅长分析代码结构和理解项目。你应该帮助用户快速理解代码库的结构和功能。",
        "tools": {
          "allowed": ["read", "grep", "glob", "list"],
          "groups": ["search"]
        },
        "permissions": {
          "inherit": false,
          "tools": {
            "read": "allow",
            "grep": "allow",
            "glob": "allow",
            "list": "allow"
          }
        }
      },
      
      "security": {
        "name": "security",
        "displayName": "安全审计",
        "description": "代码安全审计专家，专注于发现和修复安全漏洞",
        "metadata": {
          "icon": "🔒",
          "tags": ["security", "audit", "vulnerability"],
          "version": "1.0.0"
        },
        "systemPrompt": "你是一个安全审计专家，专注于发现和修复代码中的安全漏洞。你应该识别潜在的安全风险并提供修复建议。",
        "tools": {
          "allowed": ["read", "grep", "glob", "list", "bash"],
          "denied": ["write", "edit"]
        },
        "skills": {
          "allowed": ["code_analysis", "api_test"],
          "autoInitialize": true
        },
        "permissions": {
          "inherit": true,
          "tools": {
            "write": "deny",
            "edit": "deny",
            "bash": "ask"
          },
          "patterns": [
            {
              "pattern": "bash:*",
              "mode": "ask",
              "conditions": [
                { "type": "command", "operator": "contains", "value": "rm" }
              ]
            }
          ]
        },
        "model": {
          "temperature": 0.3,
          "maxTokens": 3000
        }
      }
    }
  },

  "mcp": {
    "servers": {
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/files"],
        "env": {
          "NODE_ENV": "production"
        }
      }
    }
  }
}
