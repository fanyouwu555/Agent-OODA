{
  "$schema": "https://ooda-agent.ai/config.v2.json",
  "version": "2.0",
  
  "provider": {
    "local-ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "token-unused"
      },
      "models": {
        "qwen3:8b": {
          "name": "qwen3",
          "temperature": 0.7,
          "maxTokens": 2000
        }
      }
    },
    "openai": {
      "name": "openai",
      "options": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "models": {
        "gpt-4": {
          "name": "gpt-4",
          "temperature": 0.7,
          "maxTokens": 2000
        }
      }
    }
  },

  "permission": {
    "global": {
      "defaultMode": "ask",
      "tools": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "write": "ask",
        "edit": "ask",
        "bash": "ask",
        "webfetch": "ask",
        "context7": "allow",
        "grep_app": "allow",
        "web_search": "allow",
        "web_fetch": "allow"
      },
      "skills": {
        "data_analysis": "ask",
        "image_processing": "ask",
        "pdf_processing": "ask",
        "code_analysis": "allow"
      }
    }
  },

  "agents": {
    "default": "build",
    
    "templates": {
      "base": {
        "name": "base",
        "description": "基础Agent模板",
        "config": {
          "systemPrompt": "你是一个AI助手。",
          "model": {
            "name": "qwen3",
            "temperature": 0.7,
            "maxTokens": 2000
          },
          "runtime": {
            "maxSteps": 50,
            "timeout": 300000
          }
        }
      }
    },
    
    "definitions": {
      "build": {
        "name": "build",
        "displayName": "代码构建",
        "description": "专业的代码编写助手，擅长编写高质量、可维护的代码",
        "extends": "base",
        "metadata": {
          "icon": "🔨",
          "tags": ["code", "development", "programming"],
          "author": "OODA Team",
          "version": "1.0.0",
          "examples": [
            "帮我实现一个用户登录功能",
            "写一个API接口处理用户注册"
          ]
        },
        "triggers": {
          "keywords": ["写代码", "实现", "构建", "开发", "编写", "编程"],
          "patterns": ["^(创建|编写|实现|开发).*$"],
          "fileTypes": [".ts", ".js", ".py", ".java", ".go"]
        },
        "systemPrompt": "你是一个专业的代码编写助手，擅长编写高质量、可维护的代码。你应该遵循最佳实践，编写清晰、简洁的代码。",
        "tools": {
          "allowed": ["read", "write", "edit", "bash", "grep", "glob", "list"]
        },
        "skills": {
          "allowed": ["code_analysis"],
          "autoInitialize": ["code_analysis"]
        },
        "model": {
          "temperature": 0.7,
          "maxTokens": 4000
        },
        "runtime": {
          "maxSteps": 100,
          "timeout": 600000
        }
      },
      
      "plan": {
        "name": "plan",
        "displayName": "任务规划",
        "description": "任务规划专家，擅长分析需求并制定详细的执行计划",
        "extends": "base",
        "metadata": {
          "icon": "📋",
          "tags": ["planning", "analysis", "strategy"],
          "examples": [
            "帮我规划这个项目的开发流程",
            "分析一下这个需求的实现步骤"
          ]
        },
        "triggers": {
          "keywords": ["规划", "计划", "分析", "设计", "方案"],
          "patterns": ["^(规划|计划|分析|设计).*$"]
        },
        "systemPrompt": "你是一个任务规划专家，擅长分析需求并制定详细的执行计划。你应该考虑各种可能的情况，制定周全的计划。",
        "tools": {
          "allowed": ["read", "grep", "glob", "list"]
        },
        "permissions": {
          "inherit": false,
          "tools": {
            "read": "allow",
            "grep": "allow",
            "glob": "allow",
            "list": "allow"
          }
        },
        "model": {
          "temperature": 0.5,
          "maxTokens": 1500
        }
      },
      
      "general": {
        "name": "general",
        "displayName": "通用助手",
        "description": "通用AI助手，可以处理各种任务",
        "extends": "base",
        "metadata": {
          "icon": "🤖",
          "tags": ["general", "assistant", "chat"]
        },
        "systemPrompt": "你是一个通用的AI助手，可以处理各种任务。你应该根据用户的需求，提供准确、有用的回答。",
        "tools": {
          "allowed": ["read", "write", "edit", "bash", "grep", "glob", "list", "webfetch"]
        },
        "permissions": {
          "inherit": true
        }
      },
      
      "explore": {
        "name": "explore",
        "displayName": "代码探索",
        "description": "代码探索专家，擅长分析代码结构和理解项目",
        "extends": "base",
        "metadata": {
          "icon": "🔍",
          "tags": ["explore", "codebase", "analysis"]
        },
        "triggers": {
          "keywords": ["探索", "查找", "搜索", "分析代码"],
          "fileTypes": [".ts", ".js", ".py", ".java", ".go", ".rs"]
        },
        "systemPrompt": "你是一个代码探索专家，擅长分析代码结构和理解项目。你应该帮助用户快速理解代码库的结构和功能。",
        "tools": {
          "allowed": ["read", "grep", "glob", "list"]
        },
        "permissions": {
          "inherit": false,
          "tools": {
            "read": "allow",
            "grep": "allow",
            "glob": "allow",
            "list": "allow"
          }
        }
      }
    }
  }
}
